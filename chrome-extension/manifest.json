{
  "manifest_version": 3,
  "name": "拼多多商品信息抓取",
  "version": "2.0",
  "description": "模拟人工浏览抓取商品信息：标题，主图，详情图，sku价格，sku图片，采集后生成excel表格导入到妙手ERP（跨境）",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "scripting",
    "notifications"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "License Manager",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": [
    "*://*.pinduoduo.com/*",
    "*://*.yangkeduo.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mobile.yangkeduo.com/*",
        "https://*.pinduoduo.com/*"
      ],
      "js": [
        "libs/xlsx.full.min.js",
        "content/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources":  [
        "panel/panel.html",
        "panel/panel.css",
        "panel/panel.js",
        "popup/popup.html",
        "popup/popup.css",
        "popup/popup.js"
      ],
      "matches": [
        "https://mobile.yangkeduo.com/*",
        "https://*.pinduoduo.com/*"
      ]
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}